        let timeLeft = 100 * 60; // 100 Minutes
        const timerDisplay = document.getElementById('timer');
        let countdown;
        let userAnswers = {};

        // Render Questions Dynamically
        function renderQuestions() {
            const container = document.getElementById('quizContainer');
            let htmlContent = '';

            quizData.forEach((item, index) => {
                const qId = index + 1;
                const correctAns = item.ans;
                const optA = item.opts[0];
                const optB = item.opts[1];
                const optC = item.opts[2];
                const optD = item.opts[3];

                htmlContent += `
                <div class="mcq-box" id="q${qId}" data-correct="${correctAns}">
                    <p class="question">${item.q}</p>
                    <ul class="options">
                        <li class="option-item" onclick="selectOption(${qId}, 1)">A. ${optA}</li>
                        <li class="option-item" onclick="selectOption(${qId}, 2)">B. ${optB}</li>
                        <li class="option-item" onclick="selectOption(${qId}, 3)">C. ${optC}</li>
                        <li class="option-item" onclick="selectOption(${qId}, 4)">D. ${optD}</li>
                    </ul>
                    <div class="explanation">✅ সঠিক উত্তর: ${['A','B','C','D'][correctAns-1]}. ${item.opts[correctAns-1]}<br><small>(${item.info})</small></div>
                </div>`;
            });

            container.innerHTML = htmlContent;
        }

        // Start Timer
        function startTimer() {
            countdown = setInterval(() => {
                let minutes = Math.floor(timeLeft / 60);
                let seconds = timeLeft % 60;
                seconds = seconds < 10 ? '0' + seconds : seconds;
                timerDisplay.innerText = `${minutes}:${seconds}`;
                
                if (timeLeft <= 0) {
                    clearInterval(countdown);
                    submitExam();
                }
                timeLeft--;
            }, 1000);
        }

        function selectOption(qId, optionIdx) {
            const questionBox = document.getElementById(`q${qId}`);
            if (questionBox.classList.contains('submitted')) return;

            const options = questionBox.querySelectorAll('.option-item');
            options.forEach(opt => opt.classList.remove('selected'));

            options[optionIdx - 1].classList.add('selected');
            userAnswers[qId] = optionIdx;
        }

        function submitExam() {
            clearInterval(countdown);
            
            let correctCount = 0;
            let wrongCount = 0;
            let skippedCount = 0;
            
            const allQuestions = document.querySelectorAll('.mcq-box');
            
            allQuestions.forEach((questionBox, index) => {
                const qId = index + 1;
                const correctAns = parseInt(questionBox.getAttribute('data-correct'));
                const userAns = userAnswers[qId];
                const options = questionBox.querySelectorAll('.option-item');
                const explanation = questionBox.querySelector('.explanation');

                questionBox.classList.add('submitted');

                if (userAns) {
                    if (userAns === correctAns) {
                        correctCount++;
                        options[userAns - 1].classList.add('correct');
                        questionBox.classList.add('status-correct');
                    } else {
                        wrongCount++;
                        options[userAns - 1].classList.add('wrong');
                        options[correctAns - 1].classList.add('correct');
                        questionBox.classList.add('status-wrong');
                    }
                } else {
                    skippedCount++;
                    options[correctAns - 1].classList.add('correct');
                    questionBox.classList.add('status-skipped');
                }
                
                explanation.style.display = 'block';
            });

            // Calculate Score with 0.50 negative marking
            const negativeMarks = wrongCount * 0.50;
            const finalScore = correctCount - negativeMarks;

            // UI Changes
            document.getElementById('introHeader').style.display = 'none';
            document.getElementById('submitContainer').style.display = 'none';
            document.getElementById('stickyHeader').style.display = 'none';
            document.getElementById('resultDashboard').style.display = 'block';

            // Set Scores
            document.getElementById('finalScoreDisplay').innerText = finalScore.toFixed(2);
            document.getElementById('negativeInfo').innerText = `(-${negativeMarks.toFixed(2)} ভুল উত্তরের জন্য)`;
            
            document.getElementById('countCorrect').innerText = correctCount;
            document.getElementById('countWrong').innerText = wrongCount;
            document.getElementById('countSkipped').innerText = skippedCount;

            // Scroll to Top
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // Filter Logic
        function filterQuestions(filterType, btnElement) {
            document.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
            btnElement.classList.add('active');

            const allQuestions = document.querySelectorAll('.mcq-box');

            allQuestions.forEach(box => {
                box.style.display = 'none';

                if (filterType === 'all') {
                    box.style.display = 'block';
                } else if (filterType === 'correct' && box.classList.contains('status-correct')) {
                    box.style.display = 'block';
                } else if (filterType === 'wrong' && box.classList.contains('status-wrong')) {
                    box.style.display = 'block';
                } else if (filterType === 'skipped' && box.classList.contains('status-skipped')) {
                    box.style.display = 'block';
                }
            });
        }

        // Dark Mode Logic
        function toggleDarkMode() {
            const body = document.body;
            const icon = document.getElementById('darkIcon');
            body.classList.toggle('dark-mode');
            if (body.classList.contains('dark-mode')) {
                icon.classList.remove('fa-moon');
                icon.classList.add('fa-sun');
                localStorage.setItem('theme', 'dark');
            } else {
                icon.classList.remove('fa-sun');
                icon.classList.add('fa-moon');
                localStorage.setItem('theme', 'light');
            }
        }

        window.onload = function() {
            renderQuestions(); // Render the questions first
            startTimer(); // Start the timer

            if (localStorage.getItem('theme') === 'dark') {
                document.body.classList.add('dark-mode');
                document.getElementById('darkIcon').classList.remove('fa-moon');
                document.getElementById('darkIcon').classList.add('fa-sun');
            }
        }
    </script>

